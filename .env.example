NODE_ENV=development
PORT=4000

# Database (dev: matches docker-compose.yml service name)
DATABASE_URL=postgresql://bethflow:secret@postgres:5432/bethflow

# Redis (dev: no password)
REDIS_URL=redis://redis:6379

# JWT — RS256 asymmetric keys
# Generate: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
# Then paste as single-line with literal \n:
#   awk 'NF {sub(/\r/, ""); printf "%s\\n",$0;}' private.pem
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nCHANGE_ME\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nCHANGE_ME\n-----END PUBLIC KEY-----"

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173

# SMTP — optional in dev (falls back to Ethereal preview in logs)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your@email.com
# SMTP_PASS=yourpassword
# SMTP_FROM="Bethflow <noreply@yourdomain.com>"
