NODE_ENV=development
PORT=4000

# Database
DATABASE_URL=postgresql://bethflow:secret@postgres:5432/bethflow

# Redis
REDIS_URL=redis://redis:6379

# JWT — generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Refresh token secret — generate with: openssl rand -hex 64
REFRESH_TOKEN_SECRET=change_me_64_char_hex_secret

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173

# Optional: rate limit store (defaults to memory if not set)
# REDIS_RATE_LIMIT_URL=redis://redis:6379
