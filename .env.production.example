# ============================================================
#  Bethflow — Production Environment Variables
#  Copy this file to .env.production and fill in ALL values.
#  NEVER commit .env.production to version control.
# ============================================================

NODE_ENV=production
PORT=4000

# ── Database ─────────────────────────────────────────────────
# Use a strong random password. Generate: openssl rand -hex 32
POSTGRES_DB=bethflow
POSTGRES_USER=bethflow
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

DATABASE_URL=postgresql://bethflow:CHANGE_ME_STRONG_PASSWORD@postgres:5432/bethflow

# ── Redis ────────────────────────────────────────────────────
# Password injected at runtime by docker-compose.prod.yml:
#   REDIS_URL="redis://:${REDIS_PASSWORD}@redis:6379"
# Set REDIS_PASSWORD here so docker-compose can read it.
# Generate: openssl rand -hex 32
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ── JWT — RS256 asymmetric keys ──────────────────────────────
# Generate fresh keys (do NOT reuse dev keys):
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
#
# Collapse to single line (replace newlines with \n):
#   awk 'NF {sub(/\r/, ""); printf "%s\\n",$0;}' private.pem
#
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nCHANGE_ME\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nCHANGE_ME\n-----END PUBLIC KEY-----"

# ── CORS ─────────────────────────────────────────────────────
# Set to your actual frontend domain (no trailing slash, no localhost)
ALLOWED_ORIGINS=https://yourdomain.com

# ── SMTP — required in production for OTP delivery ───────────
# Without this, verification emails are never sent to real users.
SMTP_HOST=smtp.yourmailprovider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=CHANGE_ME_SMTP_PASSWORD
SMTP_FROM="Bethflow <noreply@yourdomain.com>"
