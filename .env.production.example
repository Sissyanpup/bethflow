# ============================================================
#  Bethflow — Production Environment Variables
#  Copy to .env.production dan isi semua nilai.
#  JANGAN commit .env.production ke git.
# ============================================================

NODE_ENV=production
PORT=4000

# ── Database ─────────────────────────────────────────────────
# Generate: openssl rand -hex 32
POSTGRES_DB=bethflow
POSTGRES_USER=bethflow
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

DATABASE_URL=postgresql://bethflow:CHANGE_ME_STRONG_PASSWORD@postgres:5432/bethflow

# ── Redis ────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
# REDIS_URL harus sama dengan REDIS_PASSWORD di atas
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379

# ── JWT — RS256 asymmetric keys ──────────────────────────────
# Generate fresh keys (JANGAN pakai dev keys):
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
#   Format satu baris: awk 'NF {sub(/\r/, ""); printf "%s\\n",$0;}' private.pem
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nCHANGE_ME\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nCHANGE_ME\n-----END PUBLIC KEY-----"

# ── Refresh token secret ──────────────────────────────────────
# Generate: openssl rand -hex 64
REFRESH_TOKEN_SECRET=CHANGE_ME_REFRESH_SECRET

# ── Admin seed password ──────────────────────────────────────
# Password admin yang dibuat otomatis saat pertama kali deploy.
# WAJIB diganti setelah login pertama. Generate: openssl rand -base64 16
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# ── CORS ─────────────────────────────────────────────────────
# Domain frontend kamu (tanpa trailing slash, tanpa localhost)
ALLOWED_ORIGINS=https://yourdomain.com

# ── SMTP — pilih salah satu provider gratis di bawah ─────────
#
# OPSI 1: Brevo (direkomendasikan)
#   Gratis: 300 email/hari (9.000/bulan), tanpa CC, tanpa domain khusus
#   Daftar: https://www.brevo.com
#   Lokasi kredensial: SMTP & API > SMTP tab > Login + Master password
#
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_brevo_login_email@example.com
SMTP_PASS=your_brevo_smtp_master_password
SMTP_FROM="Bethflow <your_brevo_login_email@example.com>"
#
# OPSI 2: Resend
#   Gratis: 3.000 email/bulan, 100/hari — perlu domain verified
#   Daftar: https://resend.com
#   SMTP_HOST=smtp.resend.com
#   SMTP_PORT=465
#   SMTP_SECURE=true
#   SMTP_USER=resend
#   SMTP_PASS=re_your_api_key_here
#   SMTP_FROM="Bethflow <noreply@yourdomain.com>"
#
# OPSI 3: SendGrid
#   Gratis: 100 email/hari
#   Daftar: https://sendgrid.com
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=apikey
#   SMTP_PASS=SG.your_api_key_here
#   SMTP_FROM="Bethflow <noreply@yourdomain.com>"
