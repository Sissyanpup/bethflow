{
  "name": "@bethflow/api",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/app.js",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@bethflow/shared": "*",
    "express": "^5.0.1",
    "@prisma/client": "^5.22.0",
    "prisma": "^5.22.0",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.0.2",
    "redis": "^4.7.0",
    "socket.io": "^4.8.1",
    "helmet": "^8.0.0",
    "cors": "^2.8.5",
    "express-rate-limit": "^7.4.1",
    "rate-limit-redis": "^4.2.0",
    "sanitize-html": "^2.13.1",
    "zod": "^3.23.8",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.5"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/cors": "^2.8.17",
    "@types/sanitize-html": "^2.13.0",
    "@types/cookie-parser": "^1.4.8",
    "@types/node": "^22.9.0",
    "typescript": "^5.6.3",
    "tsx": "^4.19.2",
    "vitest": "^2.1.5",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.2"
  }
}
